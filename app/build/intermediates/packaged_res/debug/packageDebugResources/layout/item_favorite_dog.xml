<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_card"
    android:layout_marginBottom="8dp"
    android:padding="8dp">

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/image_favorite_breed"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:contentDescription="@string/title_favorites"
        android:scaleType="centerCrop"
        app:shapeAppearanceOverlay="@style/RoundedCornerImageSmall"
        app:strokeWidth="0dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <TextView
        android:id="@+id/text_favorite_breed_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="8dp"
        android:textSize="15sp"
        android:textStyle="bold"
        android:textColor="@color/black"
        app:layout_constraintStart_toEndOf="@id/image_favorite_breed"
        app:layout_constraintEnd_toStartOf="@id/button_edit_notes"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/text_favorite_notes" />

    <TextView
        android:id="@+id/text_favorite_notes"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="8dp"
        android:textSize="12sp"
        android:textColor="@color/secondary"
        android:maxLines="2"
        android:ellipsize="end"
        app:layout_constraintStart_toEndOf="@id/image_favorite_breed"
        app:layout_constraintEnd_toStartOf="@id/button_edit_notes"
        app:layout_constraintTop_toBottomOf="@id/text_favorite_breed_name"
        app:layout_constraintBottom_toBottomOf="parent" />

    <ImageView
        android:id="@+id/button_edit_notes"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:src="@android:drawable/ic_menu_edit"
        android:contentDescription="@string/edit_notes_title"
        android:padding="4dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/button_delete_favorite"
        app:layout_constraintEnd_toEndOf="parent" />

    <ImageView
        android:id="@+id/button_delete_favorite"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:src="@android:drawable/ic_menu_delete"
        android:contentDescription="@string/delete_favorite_title"
        android:padding="4dp"
        app:layout_constraintTop_toBottomOf="@id/button_edit_notes"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
