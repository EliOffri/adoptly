<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Stockly" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorAccent">@color/primary</item>
        <item name="android:colorBackground">@color/background</item>
        <item name="android:statusBarColor">@color/surface</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="chipStyle">@style/AppChipStyle</item>
        <item name="snackbarStyle">@style/Widget.Stockly.Snackbar</item>
        <item name="snackbarTextViewStyle">@style/Widget.Stockly.Snackbar.TextView</item>
        <item name="snackbarButtonStyle">@style/Widget.Stockly.Snackbar.Button</item>
    </style>

    <style name="AppChipStyle" parent="Widget.MaterialComponents.Chip.Choice">
        <item name="chipBackgroundColor">@color/surface</item>
        <item name="chipStrokeColor">@color/border</item>
        <item name="chipStrokeWidth">1.5dp</item>
        <item name="checkedIconVisible">false</item>
        <item name="chipCornerRadius">14dp</item>
        <item name="android:textColor">@color/text_muted</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="RoundedCornerImageSmall">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">14dp</item>
    </style>

    <style name="RoundedCornerImageLarge">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">18dp</item>
    </style>

    <style name="AppBottomSheetDialogTheme" parent="Theme.MaterialComponents.Light.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/AppBottomSheetStyle</item>
    </style>

    <style name="AppBottomSheetStyle" parent="Widget.MaterialComponents.BottomSheet.Modal">
        <item name="shapeAppearanceOverlay">@style/AppBottomSheetShapeAppearance</item>
        <item name="android:background">@color/surface</item>
    </style>

    <style name="AppBottomSheetShapeAppearance" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">24dp</item>
        <item name="cornerSizeTopRight">24dp</item>
        <item name="cornerSizeBottomLeft">0dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
    </style>

    <style name="Stockly.AlertDialog" parent="ThemeOverlay.MaterialComponents.MaterialAlertDialog">
        <item name="shapeAppearanceOverlay">@style/Stockly.AlertDialog.Shape</item>
        <item name="colorSurface">@color/surface</item>
        <item name="buttonBarPositiveButtonStyle">@style/Stockly.Dialog.Button.Primary</item>
        <item name="buttonBarNegativeButtonStyle">@style/Stockly.Dialog.Button.Text</item>
    </style>

    <style name="Stockly.AlertDialog.Destructive" parent="Stockly.AlertDialog">
        <item name="buttonBarPositiveButtonStyle">@style/Stockly.Dialog.Button.Destructive</item>
    </style>

    <style name="Stockly.AlertDialog.Shape">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">20dp</item>
    </style>

    <style name="Stockly.Dialog.Button.Primary" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/primary</item>
        <item name="android:textColor">@color/on_primary</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
        <item name="cornerRadius">12dp</item>
    </style>

    <style name="Stockly.Dialog.Button.Destructive" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/urgency_red</item>
        <item name="android:textColor">@color/on_primary</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
        <item name="cornerRadius">12dp</item>
    </style>

    <style name="Stockly.Dialog.Button.Text" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:textColor">@color/text_muted</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="Widget.Stockly.Button.Primary" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/primary</item>
        <item name="cornerRadius">14dp</item>
        <item name="android:textColor">@color/on_primary</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
    </style>

    <style name="Widget.Stockly.Button.Secondary" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/primary</item>
        <item name="cornerRadius">14dp</item>
        <item name="android:textColor">@color/primary_dark</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="backgroundTint">@color/primary_container</item>
    </style>

    <style name="Widget.Stockly.Snackbar" parent="Widget.MaterialComponents.Snackbar">
        <item name="backgroundTint">@color/surface</item>
        <item name="shapeAppearanceOverlay">@style/Widget.Stockly.Snackbar.Shape</item>
        <item name="android:elevation">8dp</item>
        <item name="android:layout_margin">12dp</item>
    </style>

    <style name="Widget.Stockly.Snackbar.Shape">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">14dp</item>
    </style>

    <style name="Widget.Stockly.Snackbar.TextView" parent="Widget.MaterialComponents.Snackbar.TextView">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="Widget.Stockly.Snackbar.Button" parent="Widget.MaterialComponents.Button.TextButton.Snackbar">
        <item name="android:textColor">@color/primary</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
    </style>

</resources>
